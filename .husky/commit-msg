#!/usr/bin/env sh

# Husky executa este hook via `sh -e`; precisamos desligar o errexit
# para poder capturar a saída do commitlint e imprimir a mensagem de erro.
set +e

cd "$(dirname "$0")/.."

BOLD='\033[1m'
RED='\033[31m'
YELLOW='\033[33m'
GREEN='\033[32m'
CYAN='\033[36m'
DIM='\033[2m'
RESET='\033[0m'

# Roda commitlint e captura saída + status
COMMITLINT_OUTPUT=$(npx --no -- commitlint --edit "$1" 2>&1)
COMMITLINT_STATUS=$?

if [ $COMMITLINT_STATUS -eq 0 ]; then
  exit 0
fi

# Pega a mensagem que o usuário tentou commitar
USER_MSG=$(grep -v '^#' "$1" | sed '/./,$!d' | head -1)

printf "\n"
printf "${BOLD}${RED}╔═══════════════════════════════════════════════════════════════════╗${RESET}\n"
printf "${BOLD}${RED}║  ❌ Mensagem de commit inválida                                   ║${RESET}\n"
printf "${BOLD}${RED}╚═══════════════════════════════════════════════════════════════════╝${RESET}\n\n"

printf "${DIM}Você escreveu:${RESET} ${YELLOW}\"${USER_MSG}\"${RESET}\n\n"

printf "${BOLD}📏 Formato esperado:${RESET}\n\n"
printf "   ${CYAN}<tipo>: <descrição>${RESET}\n\n"

printf "${BOLD}🏷️  Tipos válidos:${RESET}\n"
printf "   ${GREEN}feat${RESET}      ${DIM}nova funcionalidade${RESET}\n"
printf "   ${GREEN}fix${RESET}       ${DIM}correção de bug${RESET}\n"
printf "   ${GREEN}refactor${RESET}  ${DIM}refatoração${RESET}\n"
printf "   ${GREEN}perf${RESET}      ${DIM}performance${RESET}\n"
printf "   ${GREEN}style${RESET}     ${DIM}formatação${RESET}\n"
printf "   ${GREEN}test${RESET}      ${DIM}testes${RESET}\n"
printf "   ${GREEN}docs${RESET}      ${DIM}documentação${RESET}\n"
printf "   ${GREEN}chore${RESET}     ${DIM}dependências, configs${RESET}\n"
printf "   ${GREEN}ci${RESET}        ${DIM}CI/CD${RESET}\n"
printf "   ${GREEN}build${RESET}     ${DIM}build${RESET}\n"
printf "   ${GREEN}revert${RESET}    ${DIM}reverter commit${RESET}\n\n"

printf "${BOLD}✅ Exemplos válidos:${RESET}\n"
printf "   ${GREEN}feat: adiciona login${RESET}\n"
printf "   ${GREEN}fix: corrige timeout${RESET}\n"
printf "   ${GREEN}refactor: simplifica hook${RESET}\n\n"

printf "${BOLD}🔧 Como corrigir:${RESET}\n"
printf "   ${CYAN}git commit -m \"<tipo>: <descrição>\"${RESET}  ${DIM}(os arquivos seguem staged)${RESET}\n\n"

printf "${DIM}Detalhes técnicos do commitlint:${RESET}\n"
echo "$COMMITLINT_OUTPUT" | sed 's/^/   /'
printf "\n"

exit 1
